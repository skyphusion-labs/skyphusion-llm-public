// Jenkins pipeline for the video-finish Cloudflare Container.
// Builds the image and smoke-tests it (build -> run -> poll /health -> tear down).
// This validates the Dockerfile + its build-time libx264 sanity-encode in
// isolation; the actual deploy still happens via `wrangler deploy` in the root
// Jenkinsfile, which is what publishes the container image to Cloudflare.
//
// Note: no JIT/model warmup to bake here (ffmpeg is a plain subprocess), so both
// the build and the /health bind are quick. The build-time libx264 encode in the
// Dockerfile already fails fast if a slim-image ffmpeg ships without x264.
//
// Runs on a node with a usable Docker daemon (the mindcrime-ci box). NOT a docker
// agent -- we build images, so we need the host daemon, not a container sandbox.
//
// Job setup: point a Pipeline job at this Script Path
// (containers/video-finish/Jenkinsfile) and add an SCM path filter so only changes
// under containers/video-finish/ trigger it.

pipeline {
  agent any

  options {
    timeout(time: 20, unit: 'MINUTES')
    disableConcurrentBuilds()
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  environment {
    DOCKER_BUILDKIT = '1'                       // the Dockerfile uses `# syntax=...`
    CONTAINER_DIR   = 'containers/video-finish'
    IMAGE_NAME      = 'skyphusion-video-finish'
    // Match Cloudflare Containers' runtime arch so the build catches arch issues
    // on the same target prod uses.
    PLATFORM        = 'linux/amd64'
  }

  stages {
    stage('Build') {
      steps {
        sh '''
          set -eu
          docker build --platform "$PLATFORM" \
            -f "$CONTAINER_DIR/Dockerfile" \
            -t "$IMAGE_NAME:ci-$BUILD_NUMBER" \
            "$CONTAINER_DIR"
        '''
      }
    }

    stage('Smoke test (/health)') {
      steps {
        sh '''
          set -eu
          IMG="$IMAGE_NAME:ci-$BUILD_NUMBER"
          NAME="ci-$IMAGE_NAME-$BUILD_NUMBER"

          docker rm -f "$NAME" >/dev/null 2>&1 || true
          # Ephemeral host port (127.0.0.1:0) so parallel/repeat builds never collide.
          docker run -d --name "$NAME" -p 127.0.0.1:0:8000 "$IMG"

          PORT="$(docker port "$NAME" 8000/tcp | head -n1 | sed 's/.*://')"
          echo "started $NAME, /health on http://127.0.0.1:$PORT/health"

          ok=0
          for i in $(seq 1 30); do
            if curl -fsS "http://127.0.0.1:$PORT/health" >/dev/null 2>&1; then ok=1; break; fi
            sleep 2
          done

          if [ "$ok" -ne 1 ]; then
            echo "health check FAILED after ~60s; container logs:"
            docker logs "$NAME" || true
            exit 1
          fi
          echo "health OK"
        '''
      }
    }
  }

  post {
    always {
      sh '''
        NAME="ci-$IMAGE_NAME-$BUILD_NUMBER"
        docker rm -f "$NAME" >/dev/null 2>&1 || true
        docker rmi "$IMAGE_NAME:ci-$BUILD_NUMBER" >/dev/null 2>&1 || true
      '''
    }
  }
}
