{
  "name": "skyphusion-llm-public",
  "version": "0.9.4",
  "description": "Multimodal AI playground on Cloudflare Workers: chat, image gen, TTS, with R2 artifact storage and Cloudflare Access auth.",
  "license": "AGPL-3.0-only",
  "author": "Conrad Rockenhaus",
  "homepage": "https://github.com/SkyPhusion/skyphusion-llm-public",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SkyPhusion/skyphusion-llm-public.git"
  },
  "bugs": {
    "url": "https://github.com/SkyPhusion/skyphusion-llm-public/issues"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:create": "wrangler d1 create skyphusion-llm-public",
    "db:migrate:local": "wrangler d1 execute skyphusion-llm-public --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute skyphusion-llm-public --remote --file=schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "unpdf": "^1.6.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}
